{
  "css.validate": false,
  "less.validate": false,
  "scss.validate": false,
  "editor.quickSuggestions": {
    "strings": true
  },
  "tailwindCSS.experimental.classRegex": [
    ["clsx\\(([^)]*)\\)", "(?:'|\"|`)([^']*)(?:'|\"|`)"],
    ["className\\s*=\\s*{?\\s*`([^`]*)`", "(?:^|\\s)([\\w-:]+)"]
  ],
  "files.associations": {
    "*.css": "tailwindcss"
  }
}
