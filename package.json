{
  "name": "claimit",
  "version": "1.0.0",
  "description": "Find every government benefit you qualify for — free, in your language",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "pages:build": "npx @cloudflare/next-on-pages",
    "preview": "npm run pages:build && wrangler pages dev .vercel/output/static",
    "deploy": "npm run pages:build && wrangler pages deploy .vercel/output/static --project-name schemes",
    "agents:find": "node agents/findSchemes.js",
    "agents:social": "node agents/postSocial.js",
    "agents:generate": "node scripts/generate-content.js",
    "postbuild": "next-sitemap"
  },
  "dependencies": {
    "@google/generative-ai": "^0.21.0",
    "@supabase/supabase-js": "^2.101.1",
    "axios": "^1.14.0",
    "dotenv": "^17.3.1",
    "fast-xml-parser": "^5.5.9",
    "libphonenumber-js": "^1.12.40",
    "next": "14.2.5",
    "next-sitemap": "^4.2.3",
    "node-fetch": "^3.3.2",
    "openai": "^4.104.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "rss-parser": "^3.13.0"
  },
  "devDependencies": {
    "@cloudflare/next-on-pages": "^1.11.3",
    "@playwright/test": "^1.42.1",
    "@types/node": "^20.14.14",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.19",
    "esbuild": "^0.23.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.40",
    "tailwindcss": "^3.4.6",
    "typescript": "^5.5.4",
    "wrangler": "^3.101.0"
  },
  "engines": {
    "node": ">=18.17.0"
  }
}
