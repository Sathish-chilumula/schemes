{"type":"app","meta":{"headers":{"x-next-cache-tags":"_N_T_/layout,_N_T_/about/layout,_N_T_/about/page,_N_T_/about"}},"html":"<!DOCTYPE html><html lang=\"en\"><head><meta charSet=\"utf-8\"/><meta name=\"viewport\" content=\"width=device-width, initial-scale=1\"/><link rel=\"stylesheet\" href=\"/_next/static/css/bd9582d189e7beb7.css\" data-precedence=\"next\"/><link rel=\"preload\" as=\"script\" fetchPriority=\"low\" href=\"/_next/static/chunks/webpack-91b2d14d0f678b80.js\"/><script src=\"/_next/static/chunks/fd9d1056-328332afac3e0050.js\" async=\"\"></script><script src=\"/_next/static/chunks/23-916da77fcab447a2.js\" async=\"\"></script><script src=\"/_next/static/chunks/main-app-417434b60a08400d.js\" async=\"\"></script><script src=\"/_next/static/chunks/44530001-68266de4aa45c799.js\" async=\"\"></script><script src=\"/_next/static/chunks/72-68fa5f91322e76c8.js\" async=\"\"></script><script src=\"/_next/static/chunks/138-9261dfd101895d46.js\" async=\"\"></script><script src=\"/_next/static/chunks/432-2014367bf75f8af6.js\" async=\"\"></script><script src=\"/_next/static/chunks/805-0c74354901ad07f4.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/about/page-06e3b121fdee36af.js\" async=\"\"></script><script src=\"/_next/static/chunks/app/layout-190306f3ad9d5b5d.js\" async=\"\"></script><script async=\"\" src=\"https://www.googletagmanager.com/gtag/js?id=G-Z2RDTXCHHX\"></script><script async=\"\" type=\"application/javascript\" src=\"https://news.google.com/swg/js/v1/swg-basic.js\"></script><link rel=\"preconnect\" href=\"https://fonts.googleapis.com\"/><link rel=\"preconnect\" href=\"https://fonts.gstatic.com\" crossorigin=\"anonymous\"/><title>About SchemeAtlas – Transforming Benefit Discovery with AI</title><meta name=\"description\" content=\"Learn about SchemeAtlas, our mission to simplify government schemes, and how we use AI to help citizens across 50+ countries find financial aid.\"/><meta name=\"keywords\" content=\"government schemes, benefits, welfare, financial assistance, eligibility checker\"/><meta name=\"robots\" content=\"index, follow\"/><meta property=\"og:title\" content=\"SchemeAtlas .\"/><meta property=\"og:description\" content=\"Millions of people miss out on benefits they qualify for. Check yours free in 2 minutes.\"/><meta property=\"og:locale\" content=\"en_US\"/><meta property=\"og:type\" content=\"website\"/><meta name=\"twitter:card\" content=\"summary_large_image\"/><meta name=\"twitter:title\" content=\"SchemeAtlas .\"/><meta name=\"twitter:description\" content=\"Find every government scheme you qualify for. Free. Any country.\"/><link rel=\"icon\" href=\"/icon.png\"/><link rel=\"apple-touch-icon\" href=\"/icon.png\"/><script>\n              window.dataLayer = window.dataLayer || [];\n              function gtag(){dataLayer.push(arguments);}\n              gtag('js', new Date());\n              gtag('config', 'G-Z2RDTXCHHX');\n            </script><script>\n              (self.SWG_BASIC = self.SWG_BASIC || []).push( basicSubscriptions => {\n                basicSubscriptions.init({\n                  type: \"NewsArticle\",\n                  isPartOfType: [\"Product\"],\n                  isPartOfProductId: \"CAowienfCw:openaccess\",\n                  clientOptions: { theme: \"light\", lang: \"en\" },\n                });\n              });\n            </script><link href=\"https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700&amp;display=swap\" rel=\"stylesheet\"/><script src=\"/_next/static/chunks/polyfills-78c92fac7aa8fdd8.js\" noModule=\"\"></script></head><body class=\"bg-slate-50 text-slate-900 antialiased\"><!--$--><div class=\"min-h-screen bg-slate-50\"><nav class=\"bg-white/90 backdrop-blur-md border-b border-slate-200/60 sticky top-0 z-[60]\"><div class=\"page-container h-16 flex items-center justify-between\"><a class=\"flex items-center gap-2\" href=\"/\"><div class=\"w-8 h-8 bg-brand-500 rounded-lg flex items-center justify-center shadow-lg shadow-brand-500/30\"><span class=\"text-white font-bold text-sm\">C</span></div><span class=\"font-bold text-xl tracking-tight text-slate-900\">SchemeAtlas</span></a><div class=\"hidden md:flex items-center gap-6 text-sm font-medium\"><a class=\"transition-colors text-slate-600 hover:text-brand-600\" href=\"/schemes\">All Schemes</a><a class=\"transition-colors text-slate-600 hover:text-amber-500\" href=\"/saved\">🔖 Saved</a><a class=\"transition-colors text-slate-600 hover:text-brand-600\" href=\"/about\">About</a><a class=\"transition-colors text-slate-600 hover:text-brand-600\" href=\"/contact\">Contact</a></div><div class=\"flex items-center gap-3\"><div class=\"text-slate-700\"><div class=\"relative\"><button class=\"flex items-center gap-1.5 px-3 py-1.5 rounded-lg hover:bg-slate-100/10 transition-colors text-sm font-semibold text-inherit\"><span class=\"text-sm font-bold\">India</span><svg class=\"w-3.5 h-3.5 transition-transform \" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" stroke-width=\"2\" d=\"M19 9l-7 7-7-7\"></path></svg></button></div></div><a class=\"btn-primary text-sm py-2 px-5 !shadow-brand-500/40 hidden sm:inline-flex\" href=\"/in/check\">Check Eligibility →</a><button class=\"md:hidden w-10 h-10 rounded-lg flex items-center justify-center transition-colors hover:bg-slate-100 text-slate-700\" aria-label=\"Toggle menu\"><svg class=\"w-6 h-6\" fill=\"none\" viewBox=\"0 0 24 24\" stroke=\"currentColor\" stroke-width=\"2\"><path stroke-linecap=\"round\" stroke-linejoin=\"round\" d=\"M4 6h16M4 12h16M4 18h16\"></path></svg></button></div></div></nav><div class=\"page-container py-16 text-slate-800 animate-fade-in max-w-4xl mx-auto\"><h1 class=\"text-4xl font-extrabold mb-8 text-slate-900 border-b pb-4\">About SchemeAtlas</h1><div class=\"space-y-6 text-lg leading-relaxed text-slate-600\"><p>Welcome to <strong class=\"text-brand-500\">SchemeAtlas</strong>, your trusted, independent portal dedicated to helping citizens discover exactly which government schemes, assistance programs, and welfare benefits they qualify for globally.</p><p>We realized that governments worldwide offer trillions of dollars in financial aid, scholarships, housing subsidies, and business grants every year—but millions of citizens miss out simply because they <strong>don&#x27;t know the programs exist</strong>or find the eligibility criteria too confusing to understand.</p><h2 class=\"text-2xl font-bold text-slate-800 mt-8 mb-4\">Our Mission</h2><p>Our mission is to bridge the gap between complex government policy and the citizens who need it most. By utilizing advanced AI and aggregating data directly from official public sources (including <a href=\"https://myscheme.gov.in\" target=\"_blank\" rel=\"noopener noreferrer\" class=\"text-brand-500 underline hover:text-brand-600\">myscheme.gov.in</a>, PIB, and MyGov), we democratize access to welfare information.</p><h2 class=\"text-2xl font-bold text-slate-800 mt-8 mb-4\">What Makes Us Different</h2><div class=\"grid md:grid-cols-3 gap-6 mt-4\"><div class=\"card p-6 bg-white border border-slate-100 shadow-sm rounded-2xl text-center\"><span class=\"text-4xl mb-3 block\">🆓</span><h3 class=\"font-bold text-slate-900 mb-1\">100% Free</h3><p class=\"text-sm text-slate-500\">Completely free to browse, search, and check eligibility. No hidden fees, ever.</p></div><div class=\"card p-6 bg-white border border-slate-100 shadow-sm rounded-2xl text-center\"><span class=\"text-4xl mb-3 block\">🌐</span><h3 class=\"font-bold text-slate-900 mb-1\">Multilingual</h3><p class=\"text-sm text-slate-500\">Scheme guides available in English, Hindi, Telugu, Tamil, Kannada, Marathi and more regional languages.</p></div><div class=\"card p-6 bg-white border border-slate-100 shadow-sm rounded-2xl text-center\"><span class=\"text-4xl mb-3 block\">🔄</span><h3 class=\"font-bold text-slate-900 mb-1\">Updated Regularly</h3><p class=\"text-sm text-slate-500\">Our AI agents scan official portals daily to keep scheme data accurate and up-to-date.</p></div></div><div class=\"bg-brand-50 border border-brand-100 p-6 rounded-2xl mt-8\"><h3 class=\"font-bold text-brand-800 mb-2\">Independent and Non-Governmental</h3><p class=\"text-brand-700 text-base\">SchemeAtlas is a privately run educational platform. We are <strong>not affiliated with, endorsed by, or operated by any government agency</strong>. All information provided here is aggregated from thousands of public sources for informational purposes to help educate the public.</p></div><div class=\"mt-8 text-center\"><p class=\"text-slate-500 mb-4\">Have questions or suggestions?</p><a class=\"btn-primary\" href=\"/contact\">Contact Us</a></div></div></div></div><!--/$--><button id=\"chat-widget-toggle\" class=\"chat-fab\" aria-label=\"Open SchemeBot chat assistant\" title=\"Chat with SchemeBot\"><div class=\"chat-ai-icon-wrapper\"><svg width=\"28\" height=\"28\" viewBox=\"0 0 24 24\" fill=\"none\" xmlns=\"http://www.w3.org/2000/svg\"><path d=\"M12 2C6.477 2 2 6.477 2 12C2 17.523 6.477 22 12 22C17.523 22 22 17.523 22 12C22 6.477 17.523 2 12 2Z\" fill=\"url(#botGradient)\" fill-opacity=\"0.15\"></path><path d=\"M12 2C6.477 2 2 6.477 2 12C2 17.523 6.477 22 12 22C17.523 22 22 17.523 22 12C22 6.477 17.523 2 12 2Z\" stroke=\"currentColor\" stroke-width=\"1.5\"></path><rect x=\"7\" y=\"10\" width=\"10\" height=\"8\" rx=\"2\" stroke=\"currentColor\" stroke-width=\"1.5\"></rect><path d=\"M9 13H9.01M15 13H15.01\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\"></path><path d=\"M12 8V10M10 6H14\" stroke=\"currentColor\" stroke-width=\"1.5\" stroke-linecap=\"round\"></path><defs><linearGradient id=\"botGradient\" x1=\"2\" y1=\"2\" x2=\"22\" y2=\"22\" gradientUnits=\"userSpaceOnUse\"><stop stop-color=\"white\"></stop><stop offset=\"1\" stop-color=\"white\" stop-opacity=\"0\"></stop></linearGradient></defs></svg><div class=\"chat-ai-glow\"></div><span class=\"chat-fab-badge\"></span></div></button><div class=\"chat-panel \"><div class=\"chat-header\"><div class=\"chat-header-avatar\"><span>🤖</span></div><div class=\"chat-header-info\"><p class=\"chat-header-name\">SchemeBot </p><span class=\"chat-header-status\"><span class=\"chat-status-dot\"></span>AI-powered · Always online</span></div><button class=\"chat-close-btn\" aria-label=\"Close chat\"><svg width=\"16\" height=\"16\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"18\" y1=\"6\" x2=\"6\" y2=\"18\"></line><line x1=\"6\" y1=\"6\" x2=\"18\" y2=\"18\"></line></svg></button></div><div class=\"chat-messages\" id=\"chat-messages-container\"><div class=\"chat-message-row chat-message-bot\"><div class=\"chat-bot-avatar\">🤖</div><div class=\"chat-bubble chat-bubble-bot\"><span><span>👋 Hi! I'm <strong>SchemeBot</strong> — your AI guide to government benefits worldwide.</span><br/></span><span><span></span><br/></span><span><span>Tell me a bit about yourself (country, age, profession) and I'll find schemes you may qualify for!</span></span></div></div><div class=\"chat-suggestions\"><button class=\"chat-suggestion-btn\">🇮🇳 What schemes exist for farmers in India?</button><button class=\"chat-suggestion-btn\">🇬🇧 How do I apply for UK Universal Credit?</button><button class=\"chat-suggestion-btn\">🇺🇸 What is SNAP and who qualifies?</button><button class=\"chat-suggestion-btn\">💰 What benefits can I get for my family?</button></div><div></div></div><div class=\"chat-input-area\"><input id=\"chat-input-field\" type=\"text\" placeholder=\"Ask about schemes, benefits...\" class=\"chat-input\" maxLength=\"500\" autoComplete=\"off\" value=\"\"/><button disabled=\"\" class=\"chat-send-btn\" aria-label=\"Send message\" id=\"chat-send-button\"><svg width=\"18\" height=\"18\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2.5\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><line x1=\"22\" y1=\"2\" x2=\"11\" y2=\"13\"></line><polygon points=\"22 2 15 22 11 13 2 9 22 2\"></polygon></svg></button></div><p class=\"chat-footer-note\">Powered by Groq AI · SchemeAtlas</p></div><script src=\"/_next/static/chunks/webpack-91b2d14d0f678b80.js\" async=\"\"></script><script>(self.__next_f=self.__next_f||[]).push([0]);self.__next_f.push([2,null])</script><script>self.__next_f.push([1,\"1:HL[\\\"/_next/static/css/bd9582d189e7beb7.css\\\",\\\"style\\\"]\\n\"])</script><script>self.__next_f.push([1,\"2:I[5751,[],\\\"\\\"]\\n4:I[2805,[\\\"762\\\",\\\"static/chunks/44530001-68266de4aa45c799.js\\\",\\\"72\\\",\\\"static/chunks/72-68fa5f91322e76c8.js\\\",\\\"138\\\",\\\"static/chunks/138-9261dfd101895d46.js\\\",\\\"432\\\",\\\"static/chunks/432-2014367bf75f8af6.js\\\",\\\"805\\\",\\\"static/chunks/805-0c74354901ad07f4.js\\\",\\\"301\\\",\\\"static/chunks/app/about/page-06e3b121fdee36af.js\\\"],\\\"Navbar\\\"]\\n5:I[231,[\\\"762\\\",\\\"static/chunks/44530001-68266de4aa45c799.js\\\",\\\"72\\\",\\\"static/chunks/72-68fa5f91322e76c8.js\\\",\\\"138\\\",\\\"static/chunks/138-9261dfd101895d46.js\\\",\\\"432\\\",\\\"static/chunks/432-2014367bf75f8af6.js\\\",\\\"805\\\",\\\"static/chunks/805-0c74354901ad07f4.js\\\",\\\"301\\\",\\\"static/chunks/app/about/page-06e3b121fdee36af.js\\\"],\\\"\\\"]\\n6:I[9275,[],\\\"\\\"]\\n7:I[1343,[],\\\"\\\"]\\n8:I[4896,[\\\"762\\\",\\\"static/chunks/44530001-68266de4aa45c799.js\\\",\\\"72\\\",\\\"static/chunks/72-68fa5f91322e76c8.js\\\",\\\"432\\\",\\\"static/chunks/432-2014367bf75f8af6.js\\\",\\\"185\\\",\\\"static/chunks/app/layout-190306f3ad9d5b5d.js\\\"],\\\"LocationDetector\\\"]\\n9:I[5429,[\\\"762\\\",\\\"static/chunks/44530001-68266de4aa45c799.js\\\",\\\"72\\\",\\\"static/chunks/72-68fa5f91322e76c8.js\\\",\\\"432\\\",\\\"static/chunks/432-2014367bf75f8af6.js\\\",\\\"185\\\",\\\"static/chunks/app/layout-190306f3ad9d5b5d.js\\\"],\\\"ChatWidget\\\"]\\nb:I[6130,[],\\\"\\\"]\\nc:[]\\n\"])</script><script>self.__next_f.push([1,\"0