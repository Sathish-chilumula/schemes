:I[5429,[\"762\",\"static/chunks/44530001-68266de4aa45c799.js\",\"72\",\"static/chunks/72-68fa5f91322e76c8.js\",\"432\",\"static/chunks/432-2014367bf75f8af6.js\",\"185\",\"static/chunks/app/layout-190306f3ad9d5b5d.js\"],\"ChatWidget\"]\n0:[\"Ev_bMh5lYKyTdJnmq9_Ac\",[[[\"\",{\"children\":[\"privacy\",{\"children\":[\"__PAGE__\",{}]}]},\"$undefined\",\"$undefined\",true],[\"\",{\"children\":[\"privacy\",{\"children\":[\"__PAGE__\",{},[[\"$L1\",[\"$\",\"div\",null,{\"className\":\"min-h-screen bg-slate-50\",\"children\":[[\"$\",\"$L2\",null,{}],[\"$\",\"div\",null,{\"className\":\"page-container py-16 text-slate-800 max-w-4xl mx-auto\",\"children\":[[\"$\",\"h1\",null,{\"className\":\"text-4xl font-extrabold mb-8 text-slate-900 border-b pb-4\",\"children\":\"Privacy Policy\"}],[\"$\",\"div\",null,{\"className\":\"prose prose-slate max-w-none text-slate-600\",\"children\":[[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"Last Updated:\"}],\" April 2026\"]}],[\"$\",\"h3\",null,{\"children\":\"1. Information We Collect\"}],[\"$\",\"p\",null,{\"children\":[\"At SchemeAtlas, the privacy of our visitors is of extreme importance to us. We collect anonymous data regarding which schemes are viewed to improve our trending features. We also collect non-personally identifiable information voluntarily provided in our Eligibility Check wizard (such as basic income brackets, age range, and general location/state).\",[\"$\",\"strong\",null,{\"children\":\" We DO NOT collect sensitive personal data such as full names (unless volunteering via contact forms), social security numbers, or banking details.\"}]]}],[\"$\",\"p\",null,{\"children\":[[\"$\",\"strong\",null,{\"children\":\"We never sell your data.\"}],\" Your personal information is never shared with, sold to, or rented to any third party for marketing purposes.\"]}],[\"$\",\"h3\",null,{\"children\":\"2. Log Files & Cookies\"}],[\"$\",\"p\",null,{\"children\":\"Like many other Web sites, we use log files and cookies for analytics purposes only. These simply log visitors to the site — a standard procedure for hosting companies and a part of hosting services' analytics. The information includes internet protocol (IP) addresses, browser type, Internet Service Provider (ISP), date/time stamp, and referring/exit pages.\"}],[\"$\",\"h3\",null,{\"children\":\"3. Google AdSense & Third Party Advertising\"}],[\"$\",\"p\",null,{\"children\":[\"Google, as a third party vendor, uses cookies to serve ads on SchemeAtlas. Google's use of the advertising DART cookie enables it to serve ads based on users' visit to our site and other sites on the Internet. Users may opt out of the use of the DART cookie by visiting the Google ad and content network privacy policy at \",[\"$\",\"a\",null,{\"href\":\"https://policies.google.com/technologies/ads\",\"target\":\"_blank\",\"rel\":\"noopener noreferrer\",\"className\":\"text-brand-500 underline\",\"children\":\"policies.google.com/technologies/ads\"}],\".\"]}],[\"$\",\"h3\",null,{\"children\":\"4. Local Storage (Bookmarks)\"}],[\"$\",\"p\",null,{\"children\":\"Our \\\"Saved Schemes\\\" functionality relies entirely on your browser's local storage. This data never leaves your device and is not synchronized to our servers unless you explicitly sign up for a cloud account.\"}],[\"$\",\"h3\",null,{\"children\":\"5. User Accounts\"}],[\"$\",\"p\",null,{\"children\":\"If you create an account on SchemeAtlas, we store your name, email/phone for login purposes only. This data is stored securely on Supabase (our database provider) and is never shared with third parties.\"}],[\"$\",\"h3\",null,{\"children\":\"6. Contact\"}],[\"$\",\"p\",null,{\"children\":[\"If you have questions about this privacy policy, please contact us at: \",[\"$\",\"a\",null,{\"href\":\"mailto:contact@schemeatlas.com\",\"className\":\"text-brand-500 underline\",\"children\":\"contact@schemeatlas.com\"}]]}]]}]]}]]}]],null],null]},[\"$\",\"$L3\",null,{\"parallelRouterKey\":\"chil